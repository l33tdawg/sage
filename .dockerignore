# Canonical v11.9 fixture context policy. The source-ID script validates every
# effective directive below before hashing or allowing a fixture build to be
# reused. Keep this deny-by-default allowlist synchronized through
# deploy/scripts/v11.9-source-id.py; Git ignore rules are deliberately irrelevant.
**
!go.mod
!go.sum
!api/
!api/**
!cmd/
!cmd/**
!internal/
!internal/**
!third_party/
!third_party/**
!web/
!web/**

# Keep the tracked browser vendor assets embedded by web/embed.go, but exclude
# every other vendor tree. The secret/cache rules below still win inside the
# browser asset exception.
**/vendor
**/vendor/**
!web/static/js/vendor/
!web/static/js/vendor/**

# Machine-local state, credentials, databases, dependency caches, generated
# output, and editor residue never enter the fixture context or its digest.
**/.sage
**/.sage/**
